---
import { getCollection } from 'astro:content';
import TagCloud from '../../../components/TagCloud.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  getSlug,
  getTagClass,
  getTagHref,
  getTagSummaries,
  sortPostsForBlog,
} from '../../../lib/blog';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((post) => !post.data.draft);
  const tagSummaries = getTagSummaries(posts);

  return tagSummaries.map(({ tag }) => ({
    params: { tag },
    props: {
      tag,
      posts: posts.filter((post) => post.data.tags.includes(tag)).sort(sortPostsForBlog),
      tagSummaries,
    },
  }));
}

const { tag, posts, tagSummaries } = Astro.props;
---

<BaseLayout title={`${tag} | Blog | zhy12138`} description={`拥有 ${tag} tag 的文章列表。`}>
  <section class="page-head">
    <a class="back" href="/blog/">返回 Blog</a>
    <p>Tag</p>
    <h1>{tag}</h1>
  </section>

  <div class="blog-index-layout">
    <div class="blog-index-main">
      {
        posts.length > 0 ? (
          <ol class="post-list">
            {posts.map((post) => (
              <li class="post-card">
                <article>
                  <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('zh-CN')}
                  </time>
                  <h2>
                    <a class="post-link" href={`/blog/${getSlug(post.id)}/`}>{post.data.title}</a>
                  </h2>
                  {post.data.description && <p>{post.data.description}</p>}
                  {post.data.tags.length > 0 && (
                    <ul class="post-tags" aria-label="文章标签">
                      {post.data.tags.map((postTag) => (
                        <li>
                          <a
                            class:list={['post-tag', getTagClass(postTag)]}
                            href={getTagHref(postTag)}
                            aria-current={postTag === tag ? 'page' : undefined}
                          >
                            {postTag}
                          </a>
                        </li>
                      ))}
                    </ul>
                  )}
                </article>
              </li>
            ))}
          </ol>
        ) : (
          <div class="empty-state">
            <h2>暂无文章</h2>
            <p>还没有公开文章使用这个 tag。</p>
          </div>
        )
      }
    </div>
    <aside class="blog-index-aside" aria-label="标签导航">
      <TagCloud tags={tagSummaries} currentTag={tag} />
    </aside>
  </div>

  <style>
    .page-head {
      padding: 48px 0 34px;
    }

    .back {
      display: inline-flex;
      margin-bottom: 22px;
      color: var(--primary);
      font-weight: 720;
    }

    .page-head p {
      margin: 0 0 10px;
      color: var(--accent);
      font-size: 0.82rem;
      font-weight: 800;
      letter-spacing: 0;
      text-transform: uppercase;
    }

    h1 {
      margin: 0;
      font-size: clamp(2.3rem, 7vw, 4.8rem);
      line-height: 1;
      letter-spacing: 0;
    }

    .blog-index-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 220px;
      align-items: start;
      gap: 22px;
    }

    .blog-index-main {
      min-width: 0;
    }

    .blog-index-aside {
      position: sticky;
      top: 24px;
      min-width: 0;
    }

    .post-list {
      display: grid;
      gap: 14px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .post-card,
    .empty-state {
      display: block;
      padding: 24px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.84);
      box-shadow: 0 12px 30px rgba(42, 88, 138, 0.08);
    }

    .post-card:hover,
    .post-card:focus-within {
      border-color: rgba(20, 103, 216, 0.36);
      outline: none;
      transform: translateY(-1px);
    }

    .post-link {
      border-radius: 6px;
    }

    .post-link:focus-visible {
      outline: 3px solid rgba(20, 103, 216, 0.24);
      outline-offset: 3px;
    }

    time {
      color: var(--muted);
      font-size: 0.9rem;
    }

    h2 {
      margin: 10px 0 0;
      font-size: 1.35rem;
      line-height: 1.35;
      letter-spacing: 0;
    }

    .post-list p,
    .empty-state p {
      margin: 12px 0 0;
      color: var(--muted);
      line-height: 1.75;
    }

    .post-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 16px 0 0;
      padding: 0;
      list-style: none;
    }

    .post-tag {
      display: inline-flex;
      align-items: center;
      min-height: 26px;
      padding: 0 9px;
      border: 1px solid rgba(20, 103, 216, 0.18);
      border-radius: 8px;
      background: rgba(20, 103, 216, 0.08);
      color: var(--primary-strong);
      font-size: 0.82rem;
      font-weight: 760;
      line-height: 1;
    }

    .post-tag:hover,
    .post-tag:focus-visible,
    .post-tag[aria-current='page'] {
      border-color: rgba(20, 103, 216, 0.36);
      background: rgba(20, 103, 216, 0.14);
      outline: none;
    }

    .post-tag.is-course-note-tag {
      border-color: rgba(0, 167, 181, 0.28);
      background: rgba(0, 167, 181, 0.1);
      color: #075e64;
    }

    .post-tag.is-map-tag {
      border-color: rgba(191, 91, 37, 0.3);
      background: rgba(255, 180, 84, 0.16);
      color: #8f5200;
    }

    .empty-state {
      max-width: 680px;
    }

    .empty-state h2 {
      margin: 0;
    }

    @media (max-width: 760px) {
      .blog-index-layout {
        grid-template-columns: 1fr;
      }

      .blog-index-aside {
        position: static;
        order: -1;
      }
    }
  </style>
</BaseLayout>
