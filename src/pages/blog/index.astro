---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const getSlug = (id: string) => id.replace(/\.mdx?$/, '');
---

<BaseLayout title="Blog | zhy12138" description="zhy12138 的 Markdown 博客文章列表。">
  <section class="page-head">
    <p>Blog</p>
    <h1>文章</h1>
  </section>

  {
    posts.length > 0 ? (
      <ol class="post-list">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${getSlug(post.id)}/`}>
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('zh-CN')}
              </time>
              <h2>{post.data.title}</h2>
              {post.data.description && <p>{post.data.description}</p>}
            </a>
          </li>
        ))}
      </ol>
    ) : (
      <div class="empty-state">
        <h2>暂无文章</h2>
        <p>新的 Markdown 文章会从 <code>src/content/blog</code> 自动生成到这里。</p>
      </div>
    )
  }

  <style>
    .page-head {
      padding: 48px 0 34px;
    }

    .page-head p {
      margin: 0 0 10px;
      color: var(--accent);
      font-size: 0.82rem;
      font-weight: 800;
      letter-spacing: 0;
      text-transform: uppercase;
    }

    h1 {
      margin: 0;
      font-size: clamp(2.3rem, 7vw, 4.8rem);
      line-height: 1;
      letter-spacing: 0;
    }

    .post-list {
      display: grid;
      gap: 14px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .post-list a,
    .empty-state {
      display: block;
      padding: 24px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.84);
      box-shadow: 0 12px 30px rgba(42, 88, 138, 0.08);
    }

    .post-list a:hover,
    .post-list a:focus-visible {
      border-color: rgba(20, 103, 216, 0.36);
      outline: none;
      transform: translateY(-1px);
    }

    time {
      color: var(--muted);
      font-size: 0.9rem;
    }

    h2 {
      margin: 10px 0 0;
      font-size: 1.35rem;
      line-height: 1.35;
      letter-spacing: 0;
    }

    .post-list p,
    .empty-state p {
      margin: 12px 0 0;
      color: var(--muted);
      line-height: 1.75;
    }

    .empty-state {
      max-width: 680px;
    }

    .empty-state h2 {
      margin: 0;
    }

    code {
      padding: 2px 6px;
      border-radius: 6px;
      background: rgba(20, 103, 216, 0.08);
      color: var(--primary-strong);
      font-size: 0.92em;
    }
  </style>
</BaseLayout>
