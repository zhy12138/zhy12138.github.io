---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTagClass, getTagHref } from '../../lib/blog';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.id.replace(/\.mdx?$/, '') },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const isCourseNote = post.data.tags.includes('课程笔记');
const isColumn = post.data.tags.includes('专栏');
const isMapPost = post.data.tags.includes('地图');
const hasArticleToc = isCourseNote || isColumn;
const courseNoteNumberedSection = '知识点整理';
const headingCounters = [0, 0, 0, 0, 0, 0];
let isInCourseNoteNumberedSection = false;
const toc = headings.map((heading) => {
  let number = '';

  if (isColumn) {
    const index = heading.depth - 1;
    headingCounters[index] += 1;
    headingCounters.fill(0, index + 1);
    number = headingCounters.slice(0, index + 1).filter(Boolean).join('.');
  } else if (isCourseNote) {
    if (heading.depth === 1) {
      isInCourseNoteNumberedSection = heading.text === courseNoteNumberedSection;
      headingCounters.fill(0);
    } else if (isInCourseNoteNumberedSection) {
      const index = heading.depth - 2;
      headingCounters[index] += 1;
      headingCounters.fill(0, index + 1);
      number = headingCounters.slice(0, index + 1).filter(Boolean).join('.');
    }
  }

  return {
    ...heading,
    number,
  };
});
---

<BaseLayout title={`${post.data.title} | zhy12138`} description={post.data.description}>
  <div class:list={['article-layout', { 'has-article-aside': hasArticleToc }]}>
    <article class:list={['article', { 'is-course-note': isCourseNote }]}>
      <header>
        <a class="back" href="/blog/">返回 Blog</a>
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('zh-CN')}
        </time>
        {
          post.data.tags.length > 0 && (
            <ul class="article-tags" aria-label="文章标签">
              {post.data.tags.map((tag) => (
                <li>
                  <a class:list={['article-tag', getTagClass(tag)]} href={getTagHref(tag)}>
                    {tag}
                  </a>
                </li>
              ))}
            </ul>
          )
        }
        <h1>{post.data.title}</h1>
        {post.data.description && <p>{post.data.description}</p>}
      </header>
      <div
        class:list={[
          'content',
          {
            'is-course-note': isCourseNote,
            'is-column': isColumn,
            'has-article-toc': hasArticleToc,
            'is-map-post': isMapPost,
          },
        ]}
        id="article-content"
      >
        <Content />
      </div>
    </article>

    {
      hasArticleToc && (
        <aside class="article-aside" aria-label="文章目录">
          <div class="reading-card">
            <div class="progress-head">
              <span>阅读进度</span>
              <strong id="reading-percent">0%</strong>
            </div>
            <div class="progress-track" aria-hidden="true">
              <span id="reading-progress" />
            </div>
          </div>

          {toc.length > 0 && (
            <nav class="toc" aria-label="目录">
              <p>目录</p>
              <ol>
                {toc.map((heading) => (
                  <li class={`depth-${heading.depth}`}>
                    <a href={`#${heading.slug}`}>
                      {heading.number && <span class="toc-number">{heading.number}</span>}
                      <span>{heading.text}</span>
                    </a>
                  </li>
                ))}
              </ol>
            </nav>
          )}
        </aside>
      )
    }
  </div>

  <button class="back-to-top" type="button" aria-label="返回顶部" aria-hidden="true" tabindex="-1">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="m6 15 6-6 6 6" />
    </svg>
  </button>

  <script>
    const backToTopButton = document.querySelector<HTMLButtonElement>('.back-to-top');
    if (backToTopButton) {
      const button = backToTopButton;
      const backToTopThreshold = 600;
      let backToTopFrame = 0;

      function updateBackToTopState() {
        const isVisible = window.scrollY > backToTopThreshold;
        button.classList.toggle('is-visible', isVisible);
        button.setAttribute('aria-hidden', String(!isVisible));
        button.tabIndex = isVisible ? 0 : -1;
      }

      function scheduleBackToTopUpdate() {
        if (backToTopFrame) return;
        backToTopFrame = window.requestAnimationFrame(() => {
          backToTopFrame = 0;
          updateBackToTopState();
        });
      }

      button.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      updateBackToTopState();
      window.addEventListener('load', scheduleBackToTopUpdate, { once: true });
      window.addEventListener('scroll', scheduleBackToTopUpdate, { passive: true });
      window.addEventListener('resize', scheduleBackToTopUpdate);
    }

    const articleTocContent = document.querySelector<HTMLElement>('.content.has-article-toc');
    if (articleTocContent) {
      const articleTocArticle = articleTocContent;
      const isCourseNoteArticle = articleTocArticle.classList.contains('is-course-note');
      const isColumnArticle = articleTocArticle.classList.contains('is-column');
      const progressBar = document.querySelector<HTMLElement>('#reading-progress');
      const progressPercent = document.querySelector<HTMLElement>('#reading-percent');
      const tocLinks = Array.from(document.querySelectorAll('.toc a'));
      function getHashId(link: Element) {
        const href = link.getAttribute('href');
        return href?.startsWith('#') ? decodeURIComponent(href.slice(1)) : '';
      }

      const headings = tocLinks
        .map((link) => document.getElementById(getHashId(link)))
        .filter((heading): heading is HTMLElement => Boolean(heading));

      let updateFrame = 0;

      function updateArticleState() {
        if (!progressBar || !progressPercent) return;

        const rect = articleTocArticle.getBoundingClientRect();
        const readable = Math.max(1, rect.height - window.innerHeight);
        const progress = Math.min(1, Math.max(0, -rect.top / readable));
        const percent = Math.round(progress * 100);

        progressBar.style.width = `${percent}%`;
        progressPercent.textContent = `${percent}%`;

        let activeId = '';
        for (const heading of headings) {
          if (heading.getBoundingClientRect().top <= 120) {
            activeId = heading.id;
          }
        }

        let activeLink: Element | undefined;
        tocLinks.forEach((link) => {
          const isActive = getHashId(link) === activeId;
          if (isActive) activeLink = link;
          if (isActive) {
            link.setAttribute('aria-current', 'true');
          } else {
            link.removeAttribute('aria-current');
          }
        });
        activeLink?.scrollIntoView({ block: 'nearest' });
      }

      function scheduleArticleStateUpdate() {
        if (updateFrame) return;
        updateFrame = window.requestAnimationFrame(() => {
          updateFrame = 0;
          updateArticleState();
        });
      }

      function annotateArticleHeadings() {
        const numberedSectionTitle = '知识点整理';
        const counters = [0, 0, 0, 0, 0, 0];
        let isInNumberedSection = false;

        articleTocArticle
          .querySelectorAll<HTMLElement>('h1, h2, h3, h4, h5, h6')
          .forEach((heading) => {
            delete heading.dataset.noteNumber;

            const depth = Number(heading.tagName.slice(1));
            if (isColumnArticle) {
              const index = depth - 1;
              counters[index] += 1;
              counters.fill(0, index + 1);
              heading.dataset.noteNumber = counters.slice(0, index + 1).filter(Boolean).join('.');
              return;
            }

            if (isCourseNoteArticle && depth === 1) {
              isInNumberedSection = heading.textContent?.trim() === numberedSectionTitle;
              counters.fill(0);
              return;
            }

            if (!isCourseNoteArticle || !isInNumberedSection) return;

            const index = depth - 2;
            counters[index] += 1;
            counters.fill(0, index + 1);
            heading.dataset.noteNumber = counters.slice(0, index + 1).filter(Boolean).join('.');
          });
      }

      function renderQuizMath() {
        if (!('renderMathInElement' in window)) return;
        const renderMath = window.renderMathInElement as typeof import('katex/contrib/auto-render');

        articleTocArticle.querySelectorAll<HTMLElement>('.quiz-question').forEach((element) => {
          if (element.dataset.mathRendered === 'true') return;
          renderMath(element, {
            delimiters: [
              { left: '$$', right: '$$', display: true },
              { left: '$', right: '$', display: false },
              { left: '\\(', right: '\\)', display: false },
              { left: '\\[', right: '\\]', display: true },
            ],
            throwOnError: false,
          });
          element.dataset.mathRendered = 'true';
        });
      }

      function markQuizOption(question: Element, value: string | null, className: string) {
        if (!value) return;
        const input = question.querySelector<HTMLInputElement>(`input[value="${CSS.escape(value)}"]`);
        input?.closest('label')?.classList.add(className);
      }

      function lockQuiz(question: Element) {
        question.querySelectorAll<HTMLInputElement>('input[type="radio"]').forEach((input) => {
          input.disabled = true;
        });
        const actions = question.querySelector<HTMLElement>('.quiz-actions');
        if (actions) actions.hidden = true;
      }

      function getCodeLanguage(code: HTMLElement, pre: HTMLPreElement) {
        const languageClass = Array.from(code.classList).find((className) =>
          className.startsWith('language-')
        );
        return languageClass?.replace('language-', '') || pre.dataset.language || 'code';
      }

      function appendHighlightedPseudoLine(lineElement: HTMLElement, text: string) {
      const keywordPattern =
        /\b(acquire|advance|begin|break|commit|continue|disable_interrupt|elif|else|enable_interrupt|for|if|loop|pop|put|release|replace|return|rollback|stop|unlock|wait|while)\b/gi;
      let cursor = 0;

      text.replace(keywordPattern, (match, _keyword, offset: number) => {
        if (offset > cursor) {
          lineElement.append(document.createTextNode(text.slice(cursor, offset)));
        }

        const keyword = document.createElement('span');
        keyword.className = 'code-token-keyword';
        keyword.textContent = match;
        lineElement.append(keyword);
        cursor = offset + match.length;
        return match;
      });

      if (cursor < text.length) {
        lineElement.append(document.createTextNode(text.slice(cursor)));
      }
    }

      function wrapCodeLineContent(line: HTMLElement) {
      if (line.querySelector(':scope > .code-line-content')) return;

      const content = document.createElement('span');
      content.className = 'code-line-content';

      while (line.firstChild) {
        content.append(line.firstChild);
      }

      if (!content.textContent) {
        content.textContent = ' ';
      }

      line.append(content);
    }

      async function copyCode(button: HTMLButtonElement, text: string) {
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.setAttribute('readonly', '');
        textarea.style.position = 'fixed';
        textarea.style.inset = '0 auto auto -9999px';
        document.body.append(textarea);
        textarea.select();
        const legacyDocument = document as Document & {
          execCommand(commandId: 'copy'): boolean;
        };
        legacyDocument.execCommand('copy');
        textarea.remove();
      }

      button.textContent = '已复制';
      window.setTimeout(() => {
        button.textContent = '复制';
      }, 1400);
    }

      function enhanceCodeBlocks() {
        articleTocArticle.querySelectorAll<HTMLElement>('pre > code').forEach((code) => {
        const pre = code.parentElement;
        if (!(pre instanceof HTMLPreElement)) return;
        if (pre.closest('.code-frame')) return;
        if (code.classList.contains('language-html')) return;

        const rawCode = code.textContent ?? '';
        const language = getCodeLanguage(code, pre);
        const isPseudo = language === 'pseudocode' || language === 'pseudo';
        const frame = document.createElement('div');
        const toolbar = document.createElement('div');
        const label = document.createElement('span');
        const copyButton = document.createElement('button');

        frame.className = `code-frame language-${language}`;
        toolbar.className = 'code-toolbar';
        label.className = 'code-language';
        label.textContent = language === 'pseudocode' || language === 'pseudo' ? 'PSEUDO' : language.toUpperCase();
        copyButton.className = 'code-copy';
        copyButton.type = 'button';
        copyButton.textContent = '复制';
        copyButton.addEventListener('click', () => copyCode(copyButton, rawCode));

        toolbar.append(label, copyButton);
        pre.before(frame);
        frame.append(toolbar, pre);

        if (isPseudo) {
          code.replaceChildren();
          rawCode.replace(/\n$/, '').split('\n').forEach((lineText) => {
            const line = document.createElement('span');
            const content = document.createElement('span');
            line.className = 'code-line';
            content.className = 'code-line-content';
            appendHighlightedPseudoLine(content, lineText || ' ');
            line.append(content);
            code.append(line);
          });
          return;
        }

        const renderedLines = Array.from(code.children).filter(
          (child): child is HTMLElement =>
            child instanceof HTMLElement && child.classList.contains('line')
        );

        if (renderedLines.length > 0) {
          renderedLines.forEach((line) => {
            line.classList.add('code-line');
            wrapCodeLineContent(line);
          });
          code.replaceChildren(...renderedLines);
          return;
        }

        code.replaceChildren();
        rawCode.replace(/\n$/, '').split('\n').forEach((lineText) => {
          const line = document.createElement('span');
          const content = document.createElement('span');
          line.className = 'code-line';
          content.className = 'code-line-content';
          content.textContent = lineText || ' ';
          line.append(content);
          code.append(line);
        });
      });
    }

      if (isCourseNoteArticle) {
        articleTocArticle.querySelectorAll('.quiz-question').forEach((question) => {
      const answer = question.getAttribute('data-answer');
      const submitButton = question.querySelector('.submit-answer');
      const showButton = question.querySelector('.show-answer');
      const result = question.querySelector<HTMLElement>('.quiz-result');
      const explanation = question.querySelector<HTMLElement>('.quiz-explanation');

      submitButton?.addEventListener('click', () => {
        const selected = question.querySelector<HTMLInputElement>('input[type="radio"]:checked');
        if (!result || !explanation) return;

        result.hidden = false;

        if (!selected) {
          result.textContent = '请先选择一个答案。';
          result.className = 'quiz-result is-warning';
          explanation.hidden = true;
          return;
        }

        const isCorrect = selected.getAttribute('value') === answer;
        result.textContent = isCorrect ? '正确。' : '错误。';
        result.className = isCorrect ? 'quiz-result is-correct' : 'quiz-result is-wrong';
        markQuizOption(question, answer, 'is-correct-option');
        if (!isCorrect) {
          markQuizOption(question, selected.getAttribute('value'), 'is-wrong-option');
        }
        explanation.hidden = false;
        lockQuiz(question);
      });

      showButton?.addEventListener('click', () => {
        if (!result || !explanation) return;

        result.hidden = false;
        result.textContent = '已显示答案。';
        result.className = 'quiz-result is-revealed';
        markQuizOption(question, answer, 'is-correct-option');
        explanation.hidden = false;
        lockQuiz(question);
      });
        });
      }

      if (isCourseNoteArticle) enhanceCodeBlocks();
      annotateArticleHeadings();
      scheduleArticleStateUpdate();
      if (isCourseNoteArticle) {
        if (document.readyState === 'complete') {
          renderQuizMath();
        } else {
          window.addEventListener('load', renderQuizMath, { once: true });
        }
      }
      window.addEventListener('load', scheduleArticleStateUpdate, { once: true });
      window.addEventListener('scroll', scheduleArticleStateUpdate, { passive: true });
      window.addEventListener('resize', scheduleArticleStateUpdate);
      window.addEventListener('hashchange', scheduleArticleStateUpdate);
    }

    const mapPostContent = document.querySelector<HTMLElement>('.content.is-map-post');
    if (mapPostContent) {
      const mapDetailSources = new Map<string, HTMLElement>();
      const mapEditMode = new URLSearchParams(window.location.search).has('map-edit');
      const commentWalker = document.createTreeWalker(mapPostContent, NodeFilter.SHOW_COMMENT);
      const detailStartPattern = /^map-detail:([^:]+):(.+)$/;
      const commentNodes: Comment[] = [];
      let currentComment = commentWalker.nextNode();

      while (currentComment) {
        commentNodes.push(currentComment as Comment);
        currentComment = commentWalker.nextNode();
      }

      function mapDetailKey(mapId: string, targetId: string) {
        return `${mapId}::${targetId}`;
      }

      function makeMapBackButton() {
        const button = document.createElement('button');
        button.className = 'map-back';
        button.type = 'button';
        button.setAttribute('aria-label', '关闭详情');
        button.textContent = '关闭';
        return button;
      }

      commentNodes.forEach((comment) => {
        const commentText = comment.nodeValue?.trim() ?? '';
        const detailMatch = commentText.match(detailStartPattern);
        if (!detailMatch) return;

        const parent = comment.parentNode;
        if (!parent) return;

        const [, mapId, targetId] = detailMatch;
        const detailNodes: ChildNode[] = [];
        let cursor = comment.nextSibling;

        while (cursor) {
          if (cursor.nodeType === Node.COMMENT_NODE && cursor.nodeValue?.trim() === '/map-detail') break;
          detailNodes.push(cursor);
          cursor = cursor.nextSibling;
        }

        if (!cursor) return;

        const detail = document.createElement('section');
        detail.className = 'map-detail';
        detail.id = `map-detail-${mapId}-${targetId}`;
        detail.hidden = true;
        detail.tabIndex = -1;
        detail.dataset.target = targetId;
        detail.append(makeMapBackButton());
        detailNodes.forEach((node) => detail.append(node));
        mapDetailSources.set(mapDetailKey(mapId, targetId), detail);
        parent.removeChild(cursor);
        parent.removeChild(comment);
      });

      function initMapEditor(widget: HTMLElement, mapStage: HTMLElement, mapId: string) {
        if (!mapEditMode) return;

        widget.classList.add('is-map-editing');
        mapStage.setAttribute('title', '点击地图空白位置生成 marker 坐标');

        const editor = document.createElement('div');
        editor.className = 'map-editor';
        editor.setAttribute('aria-live', 'polite');
        editor.textContent = '点击地图空白位置生成 marker 片段。';
        editor.addEventListener('click', (event) => event.stopPropagation());
        mapStage.append(editor);

        function renderSnippet(snippet: string, statusText: string) {
          editor.textContent = '';

          const status = document.createElement('p');
          status.textContent = statusText;

          const code = document.createElement('code');
          code.textContent = snippet;

          const pre = document.createElement('pre');
          pre.append(code);

          editor.append(status, pre);
        }

        mapStage.addEventListener('click', (event) => {
          if ((event.target as Element | null)?.closest('.map-marker')) return;

          const rect = mapStage.getBoundingClientRect();
          const x = (((event.clientX - rect.left) / rect.width) * 100).toFixed(2);
          const y = (((event.clientY - rect.top) / rect.height) * 100).toFixed(2);
          const targetId = 'new-place';
          const snippet = `<button class="map-marker" type="button" data-x="${x}" data-y="${y}" data-target="${targetId}" aria-label="查看地点"></button>`;

          renderSnippet(snippet, `map-id: ${mapId}，坐标 x=${x} y=${y}`);
          navigator.clipboard
            ?.writeText(snippet)
            .then(() => renderSnippet(snippet, `已复制 marker 片段：x=${x} y=${y}`))
            .catch(() => renderSnippet(snippet, `无法自动复制，请手动复制：x=${x} y=${y}`));
        });
      }

      mapPostContent.querySelectorAll<HTMLElement>('.map-widget').forEach((widget, widgetIndex) => {
        const mapId = widget.dataset.mapId ?? `map-${widgetIndex + 1}`;
        widget.dataset.mapId = mapId;
        const mapStage = widget.querySelector<HTMLElement>('.map-stage');
        const markers = Array.from(widget.querySelectorAll<HTMLButtonElement>('.map-marker'));
        let detailPanel = widget.querySelector<HTMLElement>('.map-detail-panel');
        if (!detailPanel) {
          detailPanel = document.createElement('div');
          detailPanel.className = 'map-detail-panel';
          detailPanel.hidden = true;
          widget.append(detailPanel);
        }

        markers.forEach((marker) => {
          const targetId = marker.dataset.target;
          if (!targetId || detailPanel?.querySelector(`.map-detail[data-target="${CSS.escape(targetId)}"]`)) {
            return;
          }

          const detailSource = mapDetailSources.get(mapDetailKey(mapId, targetId));
          if (detailSource) detailPanel?.append(detailSource);
        });

        const details = Array.from(detailPanel.querySelectorAll<HTMLElement>('.map-detail'));
        let activeMarker: HTMLButtonElement | null = null;
        if (mapStage && !mapStage.hasAttribute('tabindex')) mapStage.tabIndex = -1;
        if (detailPanel && !detailPanel.hasAttribute('tabindex')) detailPanel.tabIndex = -1;
        details.forEach((detail) => {
          if (!detail.hasAttribute('tabindex')) detail.tabIndex = -1;
        });

        function setActiveDetail(targetId: string | null) {
          activeMarker = markers.find((marker) => marker.dataset.target === targetId) ?? null;
          markers.forEach((marker) => {
            marker.classList.toggle('is-active', Boolean(targetId) && marker.dataset.target === targetId);
            marker.setAttribute(
              'aria-expanded',
              String(Boolean(targetId) && marker.dataset.target === targetId)
            );
          });

          details.forEach((detail) => {
            detail.hidden = (detail.dataset.target ?? detail.id) !== targetId;
          });

          widget.classList.toggle('has-active-detail', Boolean(targetId));
          if (detailPanel) detailPanel.hidden = !targetId;
          document.body.classList.toggle(
            'has-map-overlay',
            Boolean(mapPostContent?.querySelector('.map-detail-panel:not([hidden])'))
          );
        }

        function closeActiveDetail() {
          const focusTarget = activeMarker;
          setActiveDetail(null);
          focusTarget?.focus();
          if (!focusTarget) mapStage?.focus();
        }

        markers.forEach((marker) => {
          marker.style.left = `${marker.dataset.x ?? '50'}%`;
          marker.style.top = `${marker.dataset.y ?? '50'}%`;
          marker.title = marker.getAttribute('aria-label') ?? '';
          marker.setAttribute('aria-expanded', 'false');

          marker.addEventListener('click', () => {
            const targetId = marker.dataset.target;
            if (!targetId) return;
            setActiveDetail(targetId);
            details.find((detail) => (detail.dataset.target ?? detail.id) === targetId)?.focus();
          });
        });

        widget.querySelectorAll<HTMLButtonElement>('.map-back').forEach((button) => {
          button.addEventListener('click', () => {
            closeActiveDetail();
          });
        });

        detailPanel?.addEventListener('click', (event) => {
          if (event.target !== detailPanel) return;
          closeActiveDetail();
        });

        widget.addEventListener('keydown', (event) => {
          if (event.key !== 'Escape') return;
          closeActiveDetail();
        });

        setActiveDetail(null);
        if (mapStage) initMapEditor(widget, mapStage, mapId);
      });
    }
  </script>

  <style>
    .article-layout {
      position: relative;
      padding: 42px 0 24px;
    }

    .article {
      max-width: 860px;
      min-width: 0;
      margin: 0 auto;
    }

    .back {
      display: inline-flex;
      margin-bottom: 22px;
      color: var(--primary);
      font-weight: 720;
    }

    time {
      display: block;
      color: var(--muted);
      font-size: 0.95rem;
    }

    .article-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin: 14px 0 0;
      padding: 0;
      list-style: none;
    }

    .article-tag {
      display: inline-flex;
      align-items: center;
      min-height: 26px;
      padding: 0 9px;
      border: 1px solid rgba(20, 103, 216, 0.18);
      border-radius: 8px;
      background: rgba(20, 103, 216, 0.08);
      color: var(--primary-strong);
      font-size: 0.82rem;
      font-weight: 760;
      line-height: 1;
    }

    .article-tag:hover,
    .article-tag:focus-visible {
      border-color: rgba(20, 103, 216, 0.36);
      background: rgba(20, 103, 216, 0.14);
      outline: none;
    }

    .article-tag.is-course-note-tag {
      border-color: rgba(0, 167, 181, 0.28);
      background: rgba(0, 167, 181, 0.1);
      color: #075e64;
    }

