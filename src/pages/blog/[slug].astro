---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.id.replace(/\.mdx?$/, '') },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const headingCounters = [0, 0, 0, 0, 0, 0];
const toc = headings.map((heading) => {
  const index = heading.depth - 1;
  headingCounters[index] += 1;
  headingCounters.fill(0, index + 1);

  return {
    ...heading,
    number: headingCounters.slice(0, index + 1).filter(Boolean).join('.'),
  };
});
---

<BaseLayout title={`${post.data.title} | zhy12138`} description={post.data.description}>
  <div class="article-layout">
    <article class="article">
      <header>
        <a class="back" href="/blog/">返回 Blog</a>
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('zh-CN')}
        </time>
        <h1>{post.data.title}</h1>
        {post.data.description && <p>{post.data.description}</p>}
      </header>
      <div class="content" id="article-content">
        <Content />
      </div>
    </article>

    <aside class="article-aside" aria-label="文章目录">
      <div class="reading-card">
        <div class="progress-head">
          <span>阅读进度</span>
          <strong id="reading-percent">0%</strong>
        </div>
        <div class="progress-track" aria-hidden="true">
          <span id="reading-progress"></span>
        </div>
      </div>

      {
        toc.length > 0 && (
          <nav class="toc" aria-label="目录">
            <p>目录</p>
            <ol>
              {toc.map((heading) => (
                <li class={`depth-${heading.depth}`}>
                  <a href={`#${heading.slug}`}>
                    <span class="toc-number">{heading.number}</span>
                    <span>{heading.text}</span>
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        )
      }
    </aside>
  </div>

  <script>
    const progressBar = document.querySelector<HTMLElement>('#reading-progress');
    const progressPercent = document.querySelector<HTMLElement>('#reading-percent');
    const article = document.querySelector<HTMLElement>('#article-content');
    const tocLinks = Array.from(document.querySelectorAll('.toc a'));
    function getHashId(link: Element) {
      const href = link.getAttribute('href');
      return href?.startsWith('#') ? decodeURIComponent(href.slice(1)) : '';
    }

    const headings = tocLinks
      .map((link) => document.getElementById(getHashId(link)))
      .filter((heading): heading is HTMLElement => Boolean(heading));

    let updateFrame = 0;

    function updateArticleState() {
      if (!article || !progressBar || !progressPercent) return;

      const rect = article.getBoundingClientRect();
      const readable = Math.max(1, rect.height - window.innerHeight);
      const progress = Math.min(1, Math.max(0, -rect.top / readable));
      const percent = Math.round(progress * 100);

      progressBar.style.width = `${percent}%`;
      progressPercent.textContent = `${percent}%`;

      let activeId = '';
      for (const heading of headings) {
        if (heading.getBoundingClientRect().top <= 120) {
          activeId = heading.id;
        }
      }

      let activeLink: Element | undefined;
      tocLinks.forEach((link) => {
        const isActive = getHashId(link) === activeId;
        if (isActive) activeLink = link;
        if (isActive) {
          link.setAttribute('aria-current', 'true');
        } else {
          link.removeAttribute('aria-current');
        }
      });
      activeLink?.scrollIntoView({ block: 'nearest' });
    }

    function scheduleArticleStateUpdate() {
      if (updateFrame) return;
      updateFrame = window.requestAnimationFrame(() => {
        updateFrame = 0;
        updateArticleState();
      });
    }

    function renderQuizMath() {
      if (!('renderMathInElement' in window)) return;
      const renderMath = window.renderMathInElement as typeof import('katex/contrib/auto-render');

      document.querySelectorAll<HTMLElement>('.quiz-question').forEach((element) => {
        if (element.dataset.mathRendered === 'true') return;
        renderMath(element, {
          delimiters: [
            { left: '$$', right: '$$', display: true },
            { left: '$', right: '$', display: false },
            { left: '\\(', right: '\\)', display: false },
            { left: '\\[', right: '\\]', display: true },
          ],
          throwOnError: false,
        });
        element.dataset.mathRendered = 'true';
      });
    }

    function markQuizOption(question: Element, value: string | null, className: string) {
      if (!value) return;
      const input = question.querySelector<HTMLInputElement>(`input[value="${CSS.escape(value)}"]`);
      input?.closest('label')?.classList.add(className);
    }

    function lockQuiz(question: Element) {
      question.querySelectorAll<HTMLInputElement>('input[type="radio"]').forEach((input) => {
        input.disabled = true;
      });
      const actions = question.querySelector<HTMLElement>('.quiz-actions');
      if (actions) actions.hidden = true;
    }

    function getCodeLanguage(code: HTMLElement, pre: HTMLPreElement) {
      const languageClass = Array.from(code.classList).find((className) =>
        className.startsWith('language-')
      );
      return languageClass?.replace('language-', '') || pre.dataset.language || 'code';
    }

    function appendHighlightedPseudoLine(lineElement: HTMLElement, text: string) {
      const keywordPattern =
        /\b(acquire|advance|begin|break|commit|continue|disable_interrupt|elif|else|enable_interrupt|for|if|loop|pop|put|release|replace|return|rollback|stop|unlock|wait|while)\b/gi;
      let cursor = 0;

      text.replace(keywordPattern, (match, _keyword, offset: number) => {
        if (offset > cursor) {
          lineElement.append(document.createTextNode(text.slice(cursor, offset)));
        }

        const keyword = document.createElement('span');
        keyword.className = 'code-token-keyword';
        keyword.textContent = match;
        lineElement.append(keyword);
        cursor = offset + match.length;
        return match;
      });

      if (cursor < text.length) {
        lineElement.append(document.createTextNode(text.slice(cursor)));
      }
    }

    function wrapCodeLineContent(line: HTMLElement) {
      if (line.querySelector(':scope > .code-line-content')) return;

      const content = document.createElement('span');
      content.className = 'code-line-content';

      while (line.firstChild) {
        content.append(line.firstChild);
      }

      if (!content.textContent) {
        content.textContent = ' ';
      }

      line.append(content);
    }

    async function copyCode(button: HTMLButtonElement, text: string) {
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.setAttribute('readonly', '');
        textarea.style.position = 'fixed';
        textarea.style.inset = '0 auto auto -9999px';
        document.body.append(textarea);
        textarea.select();
        const legacyDocument = document as Document & {
          execCommand(commandId: 'copy'): boolean;
        };
        legacyDocument.execCommand('copy');
        textarea.remove();
      }

      button.textContent = '已复制';
      window.setTimeout(() => {
        button.textContent = '复制';
      }, 1400);
    }

    function enhanceCodeBlocks() {
      document.querySelectorAll<HTMLElement>('.content pre > code').forEach((code) => {
        const pre = code.parentElement;
        if (!(pre instanceof HTMLPreElement)) return;
        if (pre.closest('.code-frame')) return;
        if (code.classList.contains('language-html')) return;

        const rawCode = code.textContent ?? '';
        const language = getCodeLanguage(code, pre);
        const isPseudo = language === 'pseudocode' || language === 'pseudo';
        const frame = document.createElement('div');
        const toolbar = document.createElement('div');
        const label = document.createElement('span');
        const copyButton = document.createElement('button');

        frame.className = `code-frame language-${language}`;
        toolbar.className = 'code-toolbar';
        label.className = 'code-language';
        label.textContent = language === 'pseudocode' || language === 'pseudo' ? 'PSEUDO' : language.toUpperCase();
        copyButton.className = 'code-copy';
        copyButton.type = 'button';
        copyButton.textContent = '复制';
        copyButton.addEventListener('click', () => copyCode(copyButton, rawCode));

        toolbar.append(label, copyButton);
        pre.before(frame);
        frame.append(toolbar, pre);

        if (isPseudo) {
          code.replaceChildren();
          rawCode.replace(/\n$/, '').split('\n').forEach((lineText) => {
            const line = document.createElement('span');
            const content = document.createElement('span');
            line.className = 'code-line';
            content.className = 'code-line-content';
            appendHighlightedPseudoLine(content, lineText || ' ');
            line.append(content);
            code.append(line);
          });
          return;
        }

        const renderedLines = Array.from(code.children).filter(
          (child): child is HTMLElement =>
            child instanceof HTMLElement && child.classList.contains('line')
        );

        if (renderedLines.length > 0) {
          renderedLines.forEach((line) => {
            line.classList.add('code-line');
            wrapCodeLineContent(line);
          });
          code.replaceChildren(...renderedLines);
          return;
        }

        code.replaceChildren();
        rawCode.replace(/\n$/, '').split('\n').forEach((lineText) => {
          const line = document.createElement('span');
          const content = document.createElement('span');
          line.className = 'code-line';
          content.className = 'code-line-content';
          content.textContent = lineText || ' ';
          line.append(content);
          code.append(line);
        });
      });
    }

    document.querySelectorAll('.quiz-question').forEach((question) => {
      const answer = question.getAttribute('data-answer');
      const submitButton = question.querySelector('.submit-answer');
      const showButton = question.querySelector('.show-answer');
      const result = question.querySelector<HTMLElement>('.quiz-result');
      const explanation = question.querySelector<HTMLElement>('.quiz-explanation');

      submitButton?.addEventListener('click', () => {
        const selected = question.querySelector<HTMLInputElement>('input[type="radio"]:checked');
        if (!result || !explanation) return;

        result.hidden = false;

        if (!selected) {
          result.textContent = '请先选择一个答案。';
          result.className = 'quiz-result is-warning';
          explanation.hidden = true;
          return;
        }

        const isCorrect = selected.getAttribute('value') === answer;
        result.textContent = isCorrect ? '正确。' : '错误。';
        result.className = isCorrect ? 'quiz-result is-correct' : 'quiz-result is-wrong';
        markQuizOption(question, answer, 'is-correct-option');
        if (!isCorrect) {
          markQuizOption(question, selected.getAttribute('value'), 'is-wrong-option');
        }
        explanation.hidden = false;
        lockQuiz(question);
      });

      showButton?.addEventListener('click', () => {
        if (!result || !explanation) return;

        result.hidden = false;
        result.textContent = '已显示答案。';
        result.className = 'quiz-result is-revealed';
        markQuizOption(question, answer, 'is-correct-option');
        explanation.hidden = false;
        lockQuiz(question);
      });
    });

    enhanceCodeBlocks();
    scheduleArticleStateUpdate();
    if (document.readyState === 'complete') {
      renderQuizMath();
    } else {
      window.addEventListener('load', renderQuizMath, { once: true });
    }
    window.addEventListener('load', scheduleArticleStateUpdate, { once: true });
    window.addEventListener('scroll', scheduleArticleStateUpdate, { passive: true });
    window.addEventListener('resize', scheduleArticleStateUpdate);
    window.addEventListener('hashchange', scheduleArticleStateUpdate);
  </script>

  <style>
    .article-layout {
      position: relative;
      padding: 42px 0 24px;
    }

    .article {
      max-width: 860px;
      min-width: 0;
      margin: 0 auto;
    }

    .back {
      display: inline-flex;
      margin-bottom: 22px;
      color: var(--primary);
      font-weight: 720;
    }

    time {
      display: block;
      color: var(--muted);
      font-size: 0.95rem;
    }

    h1 {
      margin: 12px 0 0;
      font-size: clamp(2.1rem, 7vw, 4rem);
      line-height: 1.08;
      letter-spacing: 0;
    }

    header p {
      margin: 18px 0 0;
      color: var(--muted);
      font-size: 1.08rem;
      line-height: 1.75;
    }

    .content {
      --note-strong-bg: #fff2cf;
      --note-strong-text: #6f4300;
      --note-inline-code-bg: #eef7f4;
      --note-inline-code-border: #b9ddd2;
      --note-inline-code-text: #0b6258;
      --note-code-bg: #172033;
      --note-code-line: rgba(184, 208, 240, 0.18);
      --note-code-text: #e7eefb;
      --note-code-muted: #8496b4;
      --note-code-toolbar: #111827;
      --note-code-accent: #ffd166;
      --note-code-keyword: #ffb86b;
      --note-table-head: #075e64;
      --note-table-head-line: #0f7a80;
      --note-table-row: rgba(250, 254, 253, 0.88);
      --note-table-row-alt: rgba(232, 247, 245, 0.82);
      --note-table-border: rgba(7, 94, 100, 0.24);
      --note-image-bg: #fbfdff;
      --note-image-border: #d7e5f2;
      --note-link-bg: rgba(20, 103, 216, 0.1);
      --note-link-hover-bg: rgba(20, 103, 216, 0.16);
      --note-heading-text: #321d1a;
      --note-heading-bg: #ffc8c0;
      --note-heading-border: rgba(194, 53, 58, 0.32);
      --note-heading-strong: #c2353a;
      --note-heading-mid-bg: #ffe2c2;
      --note-heading-sub-bg: #ffe8db;
      --note-heading-mid: #bf5b25;
      --note-heading-sub: #ad4638;
      --note-quiz: #4338ca;
      --note-quiz-strong: #312e81;
      --note-quiz-soft: rgba(67, 56, 202, 0.1);
      --note-quiz-line: rgba(67, 56, 202, 0.24);
      margin-top: 36px;
      padding-top: 26px;
      border-top: 1px solid var(--line);
      counter-reset: article-h1;
      line-height: 1.86;
      overflow-wrap: break-word;
    }

    .content :global(h1) {
      counter-increment: article-h1;
      counter-reset: article-h2;
    }

    .content :global(h2) {
      counter-increment: article-h2;
      counter-reset: article-h3;
    }

    .content :global(h3) {
      counter-increment: article-h3;
      counter-reset: article-h4;
    }

    .content :global(h4) {
      counter-increment: article-h4;
      counter-reset: article-h5;
    }

    .content :global(h5) {
      counter-increment: article-h5;
      counter-reset: article-h6;
    }

    .content :global(h6) {
      counter-increment: article-h6;
    }

    .content :global(h1)::before,
    .content :global(h2)::before,
    .content :global(h3)::before,
    .content :global(h4)::before,
    .content :global(h5)::before,
    .content :global(h6)::before {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex: 0 0 auto;
      color: var(--accent);
      font-variant-numeric: tabular-nums;
      font-weight: 820;
    }

    .content :global(h1)::before {
      content: counter(article-h1) '.';
    }

    .content :global(h2)::before {
      content: counter(article-h1) '.' counter(article-h2);
    }

    .content :global(h3)::before {
      content: counter(article-h1) '.' counter(article-h2) '.' counter(article-h3);
    }

    .content :global(h4)::before {
      content: counter(article-h1) '.' counter(article-h2) '.' counter(article-h3) '.'
        counter(article-h4);
    }

    .content :global(h5)::before {
      content: counter(article-h1) '.' counter(article-h2) '.' counter(article-h3) '.'
        counter(article-h4) '.' counter(article-h5);
    }

    .content :global(h6)::before {
      content: counter(article-h1) '.' counter(article-h2) '.' counter(article-h3) '.'
        counter(article-h4) '.' counter(article-h5) '.' counter(article-h6);
    }

    .content :global(h2) {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      margin: 2em 0 0.9em;
      padding: 16px 18px;
      border: 1px solid rgba(191, 91, 37, 0.32);
      border-left: 7px solid var(--note-heading-mid);
      border-radius: 8px;
      background: var(--note-heading-mid-bg);
      box-shadow: 0 12px 28px rgba(174, 72, 47, 0.13);
      color: var(--note-heading-text);
      font-size: 1.5rem;
      font-weight: 820;
      line-height: 1.3;
      letter-spacing: 0;
    }

    .content :global(h1) {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      margin: 2.2em 0 0.95em;
      padding: 18px 20px;
      border: 1px solid var(--note-heading-border);
      border-left: 6px solid var(--note-heading-strong);
      border-radius: 8px;
      background: var(--note-heading-bg);
      box-shadow: 0 16px 34px rgba(194, 53, 58, 0.15);
      color: var(--note-heading-text);
      font-size: 1.78rem;
      line-height: 1.28;
      letter-spacing: 0;
    }

    .content :global(h1)::before {
      min-width: 2.1em;
      margin-top: 0.02em;
      padding: 0.1em 0.38em;
      border-radius: 7px;
      background: var(--note-heading-strong);
      color: white;
      font-size: 0.74em;
      line-height: 1.45;
    }

    .content :global(h2)::before {
      min-width: 2.5em;
      margin-top: 0.08em;
      padding: 0.08em 0.48em;
      border: 0;
      border-radius: 7px;
      background: var(--note-heading-mid);
      color: white;
      font-size: 0.7em;
      line-height: 1.55;
    }

    .content :global(h3) {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      width: fit-content;
      max-width: 100%;
      margin: 1.75em 0 0.8em;
      padding: 10px 13px;
      border: 1px solid rgba(173, 70, 56, 0.3);
      border-left: 5px solid var(--note-heading-sub);
      border-radius: 8px;
      background: var(--note-heading-sub-bg);
      box-shadow: 0 8px 22px rgba(173, 70, 56, 0.12);
      color: var(--note-heading-sub);
      font-size: 1.26rem;
      font-weight: 800;
      line-height: 1.4;
      letter-spacing: 0;
    }

    .content :global(h3)::before {
      margin-top: 0.05em;
      padding: 0.02em 0.44em;
      border-radius: 6px;
      background: var(--note-heading-sub);
      color: white;
      font-size: 0.72em;
      line-height: 1.6;
    }

    .content :global(h4),
    .content :global(h5),
    .content :global(h6) {
      display: flex;
      align-items: baseline;
      gap: 7px;
      margin: 1.45em 0 0.62em;
      color: #26394f;
      font-size: 1rem;
      line-height: 1.45;
      letter-spacing: 0;
    }

    .content :global(h4)::before,
    .content :global(h5)::before,
    .content :global(h6)::before {
      color: var(--muted);
      font-size: 0.82em;
    }

    .content :global(p) {
      margin: 1.1em 0;
    }

    .content :global(ul),
    .content :global(ol) {
      margin: 1em 0;
      padding-left: 1.45em;
    }

    .content :global(li) {
      margin: 0.34em 0;
      padding-left: 0.1em;
    }

    .content :global(li > ul),
    .content :global(li > ol) {
      margin: 0.36em 0 0.5em;
    }

    .content :global(a) {
      border-radius: 4px;
      background:
        linear-gradient(var(--note-link-bg), var(--note-link-bg)) 0 88% / 100% 0.42em
          no-repeat;
      color: var(--primary-strong);
      font-weight: 660;
      text-decoration: none;
      transition:
        background-size 140ms ease,
        background-color 140ms ease,
        color 140ms ease;
    }

    .content :global(a:hover),
    .content :global(a:focus-visible) {
      background:
        linear-gradient(var(--note-link-hover-bg), var(--note-link-hover-bg)) 0 88% / 100%
          0.86em no-repeat;
      color: #083d83;
      outline: none;
    }

    .content :global(strong) {
      padding: 0.08em 0.26em;
      border-radius: 5px;
      background: linear-gradient(180deg, transparent 18%, var(--note-strong-bg) 18%);
      color: var(--note-strong-text);
      font-weight: 760;
      box-decoration-break: clone;
      -webkit-box-decoration-break: clone;
    }

    .content :global(code) {
      padding: 0.12em 0.42em;
      border: 1px solid var(--note-inline-code-border);
      border-radius: 6px;
      background: var(--note-inline-code-bg);
      color: var(--note-inline-code-text);
      font-family:
        "SFMono-Regular", Consolas, "Liberation Mono", Menlo, ui-monospace, monospace;
      font-size: 0.9em;
      line-height: 1.5;
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    .content :global(.code-frame) {
      margin: 1.25em 0;
      border: 1px solid var(--note-code-line);
      border-radius: 8px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.05), transparent 56px),
        var(--note-code-bg);
      box-shadow: 0 16px 34px rgba(16, 24, 39, 0.16);
      overflow: hidden;
    }

    .content :global(.code-toolbar) {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      min-height: 42px;
      padding: 8px 10px 8px 14px;
      border-bottom: 1px solid var(--note-code-line);
      background: rgba(17, 24, 39, 0.78);
    }

    .content :global(.code-language) {
      color: var(--note-code-accent);
      font-size: 0.76rem;
      font-weight: 820;
      letter-spacing: 0.08em;
      line-height: 1;
    }

    .content :global(.code-copy) {
      min-height: 30px;
      padding: 0 11px;
      border: 1px solid rgba(255, 209, 102, 0.34);
      border-radius: 7px;
      background: rgba(255, 209, 102, 0.1);
      color: #ffe6a3;
      font: inherit;
      font-size: 0.78rem;
      font-weight: 760;
      line-height: 1;
      cursor: pointer;
    }

    .content :global(.code-copy:hover),
    .content :global(.code-copy:focus-visible) {
      border-color: rgba(255, 209, 102, 0.68);
      background: rgba(255, 209, 102, 0.18);
      color: white;
      outline: none;
    }

    .content :global(pre) {
      margin: 0;
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
    }

    .content :global(pre code) {
      display: block;
      min-width: max-content;
      padding: 14px 0;
      border: 0;
      border-radius: 0;
      background: transparent;
      color: var(--note-code-text);
      font-size: 0.9rem;
      line-height: 1.55;
      overflow-wrap: normal;
      tab-size: 2;
      white-space: pre;
      word-break: normal;
    }

    .content :global(.code-line) {
      display: grid;
      grid-template-columns: 42px max-content;
      align-items: start;
      padding: 0 20px 0 0;
      counter-increment: code-line;
      line-height: inherit;
    }

    .content :global(.code-line)::before {
      content: counter(code-line);
