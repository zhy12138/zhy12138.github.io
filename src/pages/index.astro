---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const getSlug = (id: string) => id.replace(/\.mdx?$/, '');
---

<BaseLayout title="Home | zhy12138" description="zhy12138 的个人网站与 Markdown 博客入口。">
  <section class="hero" aria-labelledby="hero-title">
    <div class="profile" aria-label="个人名片">
      <img src="/avatar.jpg" alt="zhy12138 avatar" width="128" height="128" />
      <div>
        <p class="eyebrow">Personal Site</p>
        <h1 id="hero-title" class="profile-title">zhy12138</h1>
        <p class="profile-meta">人生如逆旅，我亦是行人</p>
      </div>
      <div class="actions" aria-label="常用链接">
        <a class="button primary" href="/blog/">Blog</a>
        <a class="button" href="https://github.com/zhy12138" rel="noreferrer">GitHub</a>
        <a class="button" href="mailto:2065148766@qq.com">Email</a>
      </div>
    </div>

    <div class="about">
      <p class="eyebrow">About me</p>
      <h2>关于我</h2>
      <p class="intro">PKU 信科大四在读菜鸟一只。</p>
      <p class="intro">这里收录了我的一些课程笔记和碎碎念，内容尚嫩，欢迎路过的大佬指出错误，也欢迎一起交流。</p>
    </div>
  </section>

  <section class="latest-posts" aria-labelledby="latest-posts-title">
    <div class="section-head">
      <div>
        <p class="eyebrow">Latest Posts</p>
        <h2 id="latest-posts-title">最新文章</h2>
      </div>
      <a class="view-all" href="/blog/">查看全部</a>
    </div>

    {
      posts.length > 0 ? (
        <ol class="post-preview-list">
          {posts.map((post) => (
            <li>
              <a href={`/blog/${getSlug(post.id)}/`}>
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('zh-CN')}
                </time>
                <h3>{post.data.title}</h3>
                {post.data.description && <p>{post.data.description}</p>}
              </a>
            </li>
          ))}
        </ol>
      ) : (
        <div class="empty-state">
          <h3>暂无公开文章</h3>
          <p>新的 Markdown 文章会显示在这里。</p>
        </div>
      )
    }
  </section>

  <style>
    .hero {
      display: grid;
      grid-template-columns: minmax(280px, 340px) minmax(0, 1fr);
      align-items: center;
      gap: 56px;
      min-height: clamp(520px, calc(100vh - 340px), 640px);
      padding: 48px 0 38px;
    }

    .eyebrow {
      margin: 0 0 14px;
      color: var(--accent);
      font-size: 0.82rem;
      font-weight: 800;
      letter-spacing: 0;
      text-transform: uppercase;
    }

    .profile-title {
      margin: 0;
      overflow-wrap: anywhere;
      font-size: 2.35rem;
      line-height: 1.05;
      letter-spacing: 0;
    }

    h2 {
      margin: 0;
      font-size: clamp(2.5rem, 8vw, 5.4rem);
      line-height: 1;
      letter-spacing: 0;
    }

    .intro {
      max-width: 640px;
      margin: 26px 0 0;
      color: var(--muted);
      font-size: 1.18rem;
      line-height: 1.85;
    }

    .actions {
      display: grid;
      width: 100%;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
      margin-top: 12px;
    }

    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      padding: 0 12px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.78);
      color: var(--text);
      font-weight: 720;
      box-shadow: 0 10px 24px rgba(42, 88, 138, 0.08);
    }

    .button:hover,
    .button:focus-visible {
      border-color: rgba(20, 103, 216, 0.35);
      color: var(--primary-strong);
      outline: none;
      transform: translateY(-1px);
    }

    .button.primary {
      border-color: transparent;
      background: var(--primary);
      color: white;
    }

    .profile {
      display: grid;
      justify-items: center;
      gap: 22px;
      padding: 30px;
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 8px;
      background:
        linear-gradient(135deg, rgba(255, 180, 84, 0.12), transparent 36%),
        rgba(255, 255, 255, 0.86);
      box-shadow: var(--shadow);
      text-align: center;
    }

    .profile img {
      width: 128px;
      height: 128px;
      border: 4px solid #fff;
      border-radius: 50%;
      object-fit: cover;
      box-shadow: 0 14px 34px rgba(20, 103, 216, 0.18);
    }

    .profile-meta {
      margin: 8px 0 0;
      color: var(--muted);
      font-size: 0.95rem;
      line-height: 1.6;
    }

    .about {
      min-width: 0;
      max-width: 680px;
    }

    .latest-posts {
      padding: 0 0 20px;
    }

    .section-head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 24px;
      margin-bottom: 18px;
    }

    .section-head h2 {
      font-size: clamp(2rem, 6vw, 3.6rem);
    }

    .view-all {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 40px;
      padding: 0 14px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.78);
      color: var(--primary-strong);
      font-weight: 720;
      white-space: nowrap;
    }

    .view-all:hover,
    .view-all:focus-visible {
      border-color: rgba(20, 103, 216, 0.35);
      outline: none;
      box-shadow: 0 10px 24px rgba(42, 88, 138, 0.08);
    }

    .post-preview-list {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .post-preview-list a,
    .empty-state {
      display: block;
      min-height: 132px;
      padding: 22px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.84);
      box-shadow: 0 12px 30px rgba(42, 88, 138, 0.08);
    }

    .post-preview-list a:hover,
    .post-preview-list a:focus-visible {
      border-color: rgba(0, 167, 181, 0.42);
      outline: none;
      transform: translateY(-1px);
    }

    time {
      color: var(--muted);
      font-size: 0.9rem;
    }

    h3 {
      margin: 10px 0 0;
      font-size: 1.18rem;
      line-height: 1.35;
      letter-spacing: 0;
    }

    .post-preview-list p,
    .empty-state p {
      margin: 12px 0 0;
      color: var(--muted);
      line-height: 1.75;
    }

    .empty-state {
      max-width: 680px;
      min-height: 0;
    }

    @media (max-width: 820px) {
      .hero {
        grid-template-columns: 1fr;
        gap: 32px;
        min-height: auto;
        padding-top: 36px;
      }

      .profile {
        justify-items: start;
        grid-template-columns: auto minmax(0, 1fr);
        align-items: center;
        text-align: left;
      }

      .actions {
        grid-column: 1 / -1;
      }

      .profile img {
        width: 88px;
        height: 88px;
      }

      .post-preview-list {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 480px) {
      .hero {
        padding-top: 18px;
      }

      .profile {
        grid-template-columns: 1fr;
        justify-items: center;
        text-align: center;
      }

      .actions {
        grid-template-columns: 1fr;
      }

      .profile-title {
        font-size: 2rem;
      }

      .section-head {
        align-items: flex-start;
        flex-direction: column;
      }
    }
  </style>
</BaseLayout>
