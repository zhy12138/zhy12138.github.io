---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'zhy12138 的个人网站与 Markdown 博客。',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="stylesheet" href="/katex/katex.min.css" />
    <script is:inline defer src="/katex/katex.min.js"></script>
    <script is:inline defer src="/katex/contrib/auto-render.min.js"></script>
    <title>{title}</title>
    <style is:global>
      :root {
        color-scheme: light;
        --bg: #f7fbff;
        --panel: #ffffff;
        --text: #142033;
        --muted: #5c697a;
        --line: #dce8f5;
        --primary: #1467d8;
        --primary-strong: #0b4ea8;
        --accent: #00a7b5;
        --warm: #ffb454;
        --shadow: 0 18px 45px rgba(42, 88, 138, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-width: 320px;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
        color: var(--text);
        background:
          linear-gradient(120deg, rgba(20, 103, 216, 0.08), transparent 38%),
          linear-gradient(240deg, rgba(0, 167, 181, 0.08), transparent 42%),
          var(--bg);
      }

      body::before {
        position: fixed;
        inset: 0;
        z-index: -1;
        pointer-events: none;
        content: "";
        background-image:
          linear-gradient(rgba(20, 103, 216, 0.07) 1px, transparent 1px),
          linear-gradient(90deg, rgba(20, 103, 216, 0.07) 1px, transparent 1px);
        background-size: 40px 40px;
        mask-image: linear-gradient(to bottom, #000 0%, transparent 75%);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .site-shell {
        width: min(1080px, calc(100% - 32px));
        margin: 0 auto;
      }

      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        padding: 24px 0;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
        font-weight: 750;
      }

      .brand-mark {
        display: grid;
        width: 34px;
        height: 34px;
        place-items: center;
        flex: 0 0 auto;
      }

      .brand-mark img {
        display: block;
        width: 34px;
        height: 34px;
        object-fit: contain;
      }

      .brand-text {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .site-nav {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .site-nav a {
        padding: 9px 12px;
        border-radius: 8px;
        color: var(--muted);
        font-size: 0.95rem;
      }

      .site-nav a:hover,
      .site-nav a:focus-visible {
        color: var(--primary-strong);
        background: rgba(20, 103, 216, 0.08);
        outline: none;
      }

      main {
        padding: 28px 0 56px;
      }

      .site-footer {
        padding: 28px 0 36px;
        color: var(--muted);
        font-size: 0.9rem;
      }

      .music-player {
        position: fixed;
        right: 24px;
        bottom: 24px;
        z-index: 20;
      }

      .music-player__toggle,
      .music-player__refresh,
      .music-player__close {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(220, 232, 245, 0.9);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.88);
        color: var(--text);
        box-shadow: 0 10px 30px rgba(42, 88, 138, 0.14);
        cursor: pointer;
        font: inherit;
      }

      .music-player__toggle {
        width: 44px;
        height: 44px;
        padding: 0;
        border-radius: 999px;
        color: var(--primary-strong);
      }

      .music-player__toggle svg {
        width: 20px;
        height: 20px;
        stroke-width: 2.2;
      }

      .music-player__toggle:hover,
      .music-player__toggle:focus-visible,
      .music-player__refresh:hover,
      .music-player__refresh:focus-visible,
      .music-player__close:hover,
      .music-player__close:focus-visible {
        border-color: rgba(20, 103, 216, 0.24);
        background: rgba(255, 255, 255, 0.96);
        outline: none;
      }

      .music-player__refresh:disabled {
        cursor: wait;
        opacity: 0.58;
      }

      .music-player__panel {
        display: none;
        position: relative;
        width: 420px;
        overflow: visible;
        border: 1px solid rgba(220, 232, 245, 0.9);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.9);
        box-shadow: var(--shadow);
      }

      .music-player[data-open="true"] .music-player__toggle {
        display: none;
      }

      .music-player[data-open="true"] .music-player__panel {
        display: block;
      }

      .music-player__mount {
        width: 420px;
      }

      .music-player__mount.aplayer,
      .music-player__mount .aplayer {
        margin: 0 !important;
        border-radius: 0 0 8px 8px !important;
        box-shadow: none !important;
      }

      .music-player__mount.aplayer .aplayer-list,
      .music-player__mount .aplayer-list {
        max-height: 260px !important;
        overflow-y: auto !important;
      }

      .music-player__mount.aplayer .aplayer-volume-bar-wrap,
      .music-player__mount .aplayer-volume-bar-wrap {
        z-index: 30;
      }

      .music-player__mount.aplayer .aplayer-icon-back,
      .music-player__mount.aplayer .aplayer-icon-forward,
      .music-player__mount .aplayer-icon-back,
      .music-player__mount .aplayer-icon-forward {
        display: inline-block !important;
      }

      .music-player__frame {
        display: block;
        width: 420px;
        height: 86px;
        border: 0;
      }

      .music-player__status {
        display: grid;
        min-height: 110px;
        padding: 36px 42px 18px 18px;
        place-items: center;
        color: var(--muted);
        font-size: 0.9rem;
        line-height: 1.6;
        text-align: center;
      }

      .music-player__toolbar {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 6px;
        min-height: 34px;
        padding: 5px 6px;
        border-bottom: 1px solid rgba(220, 232, 245, 0.78);
        background: rgba(255, 255, 255, 0.92);
        border-radius: 8px 8px 0 0;
      }

      .music-player__refresh,
      .music-player__close {
        width: 24px;
        height: 24px;
        padding: 0;
        color: var(--muted);
        font-size: 1rem;
        line-height: 1;
      }

      @media (max-width: 640px) {
        .site-shell {
          width: min(100% - 24px, 1080px);
        }

        .site-header {
          align-items: flex-start;
          flex-direction: column;
          gap: 14px;
        }

        .site-nav {
          width: 100%;
          justify-content: flex-start;
        }

        .music-player {
          display: none;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header site-shell">
      <a class="brand" href="/" aria-label="返回首页">
        <span class="brand-mark" aria-hidden="true">
          <img src="/favicon.png" alt="" />
        </span>
        <span class="brand-text">zhy12138</span>
      </a>
      <nav class="site-nav" aria-label="主导航">
        <a href="/">首页</a>
        <a href="/blog/">Blog</a>
        <a href="https://github.com/zhy12138" rel="noreferrer">GitHub</a>
      </nav>
    </header>
    <main class="site-shell">
      <slot />
    </main>
    <footer class="site-footer site-shell">
      <span>© {new Date().getFullYear()} zhy12138</span>
    </footer>
    <aside class="music-player" data-open="false" aria-label="音乐播放器">
      <button class="music-player__toggle" type="button" aria-label="打开音乐播放器" aria-expanded="false">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 18V5l12-2v13" />
          <circle cx="6" cy="18" r="3" />
          <circle cx="18" cy="16" r="3" />
        </svg>
      </button>
      <div class="music-player__panel">
        <div class="music-player__toolbar" aria-label="音乐播放器控制">
          <button class="music-player__refresh" type="button" aria-label="刷新音乐播放器">
            ↻
          </button>
          <button class="music-player__close" type="button" aria-label="收起音乐播放器">
            –
          </button>
        </div>
        <div class="music-player__mount" data-fallback-id="3320085018"></div>
      </div>
    </aside>
    <script is:inline>
      const musicPlayer = document.querySelector(".music-player");
      const musicToggle = musicPlayer?.querySelector(".music-player__toggle");
      const musicRefresh = musicPlayer?.querySelector(".music-player__refresh");
      const musicClose = musicPlayer?.querySelector(".music-player__close");
      const musicMount = musicPlayer?.querySelector(".music-player__mount");
      const musicPlaylistUrl = "/music/playlist.json";
      const aplayerStyleUrl = "https://cdn.jsdelivr.net/npm/aplayer@1.10.1/dist/APlayer.min.css";
      const aplayerScriptUrl = "https://cdn.jsdelivr.net/npm/aplayer@1.10.1/dist/APlayer.min.js";
      const metingApiUrl = "https://api.i-meto.com/meting/api";
      let musicPlayerInstance;
      let musicLoadToken = 0;
      let musicVolumeFixController;

      const hasAPlayerStylesheet = () =>
        Array.from(document.querySelectorAll('link[rel="stylesheet"]')).some(
          (link) => link.href === aplayerStyleUrl,
        );

      const getExternalScript = (src) =>
        Array.from(document.scripts).find((script) => script.src === src);

      const loadExternalScript = (src) =>
        new Promise((resolve, reject) => {
          const current = getExternalScript(src);
          if (current?.dataset.loaded === "true") {
            resolve();
            return;
          }

          const script = current || document.createElement("script");
          script.src = src;
          script.async = true;
          script.addEventListener("load", () => {
            script.dataset.loaded = "true";
            resolve();
          }, { once: true });
          script.addEventListener("error", reject, { once: true });
          if (!current) document.head.append(script);
        });

      const setMusicLoading = (isLoading) => {
        if (!musicRefresh) return;
        musicRefresh.disabled = isLoading;
        musicRefresh.setAttribute("aria-busy", String(isLoading));
      };

      const showMusicStatus = (message) => {
        if (!musicMount) return;
        musicMount.innerHTML = `<div class="music-player__status">${message}</div>`;
      };

      const resetMusicMount = () => {
        musicVolumeFixController?.abort();
        musicVolumeFixController = undefined;
        musicPlayerInstance?.destroy?.();
        musicPlayerInstance = undefined;
        if (musicMount) musicMount.textContent = "";
      };

      const ensureAPlayer = async () => {
        if (!hasAPlayerStylesheet()) {
          const link = document.createElement("link");
          link.rel = "stylesheet";
          link.href = aplayerStyleUrl;
          document.head.append(link);
        }

        if (!window.APlayer) {
          await loadExternalScript(aplayerScriptUrl);
        }

        if (!window.APlayer) {
          throw new Error("APlayer is unavailable.");
        }
      };

      const getMetingSong = async (server, id) => {
        const url = new URL(metingApiUrl);
        url.searchParams.set("server", server);
        url.searchParams.set("type", "song");
        url.searchParams.set("id", String(id));
        url.searchParams.set("r", `${Date.now()}-${Math.random()}`);

        const response = await fetch(url);
        if (!response.ok) throw new Error(`Song ${id} returned ${response.status}.`);

        const songs = await response.json();
        const song = Array.isArray(songs) ? songs[0] : undefined;
        if (!song?.url || !song?.title) {
          throw new Error(`Song ${id} has no playable metadata.`);
        }

        return {
          name: song.title,
          artist: song.author || "Unknown Artist",
          url: song.url,
          cover: song.pic,
          lrc: song.lrc,
        };
      };

      const getPlaylistConfig = async () => {
        const response = await fetch(`${musicPlaylistUrl}?r=${Date.now()}`);
        if (!response.ok) throw new Error(`Playlist returned ${response.status}.`);

        const config = await response.json();
        const tracks = Array.isArray(config.tracks)
          ? config.tracks.map((track) => String(track).trim()).filter(Boolean)
          : [];

        return {
          server: config.server || "netease",
          tracks,
        };
      };

      const getMusicPlaylist = async (config) => {
        const results = await Promise.allSettled(
          config.tracks.map((id) => getMetingSong(config.server, id)),
        );

        return results
          .filter((result) => result.status === "fulfilled")
          .map((result) => result.value);
      };

      const restoreInitialVolume = () => {
        const audio = musicPlayerInstance?.audio;
        if (!audio) return;

        audio.muted = false;
        if (audio.volume === 0) {
          audio.volume = 0.7;
          musicPlayerInstance.volume?.(0.7, true);
        }
      };

      const installAPlayerVolumeFix = () => {
        const volumeBarWrap = musicMount?.querySelector(".aplayer-volume-bar-wrap");
        if (!volumeBarWrap || volumeBarWrap.dataset.scrollFix === "true") return;
        volumeBarWrap.dataset.scrollFix = "true";
        musicVolumeFixController = new AbortController();
        const { signal } = musicVolumeFixController;

        let isAdjustingVolume = false;

        const getClientY = (event) => {
          const touch = event.touches?.[0] || event.changedTouches?.[0];
          return touch ? touch.clientY : event.clientY;
        };

        const setVolumeFromEvent = (event) => {
          const rect = volumeBarWrap.getBoundingClientRect();
          if (!rect.height) return;

          const volume = Math.max(0, Math.min(1, (rect.bottom - getClientY(event)) / rect.height));
          const audio = musicPlayerInstance?.audio;
          if (audio) audio.muted = false;
          musicPlayerInstance?.volume?.(volume, true);
        };

        const beginVolumeAdjust = (event) => {
          isAdjustingVolume = true;
          event.preventDefault();
          event.stopImmediatePropagation();
          setVolumeFromEvent(event);
        };

        const moveVolumeAdjust = (event) => {
          if (!isAdjustingVolume) return;
          event.preventDefault();
          event.stopImmediatePropagation();
          setVolumeFromEvent(event);
        };

        const endVolumeAdjust = () => {
          isAdjustingVolume = false;
        };

        volumeBarWrap.addEventListener("mousedown", beginVolumeAdjust, { capture: true, signal });
        volumeBarWrap.addEventListener("touchstart", beginVolumeAdjust, { capture: true, passive: false, signal });
        document.addEventListener("mousemove", moveVolumeAdjust, { capture: true, signal });
        document.addEventListener("touchmove", moveVolumeAdjust, { capture: true, passive: false, signal });
        document.addEventListener("mouseup", endVolumeAdjust, { capture: true, signal });
        document.addEventListener("touchend", endVolumeAdjust, { capture: true, signal });
        document.addEventListener("touchcancel", endVolumeAdjust, { capture: true, signal });
      };

      const loadFallbackFrame = (trackId) => {
        if (!musicMount || !trackId) return;
        const url = new URL("https://music.163.com/outchain/player");
        url.searchParams.set("type", "2");
        url.searchParams.set("id", String(trackId));
        url.searchParams.set("auto", "1");
        url.searchParams.set("height", "66");

        musicMount.innerHTML = "";
        const frame = document.createElement("iframe");
        frame.className = "music-player__frame";
        frame.title = "网易云音乐播放器";
        frame.src = url.toString();
        frame.allow = "autoplay; encrypted-media";
        frame.loading = "lazy";
        musicMount.append(frame);
      };

      const loadMusicPlayer = async ({ force = false } = {}) => {
        if (!musicMount || (musicPlayerInstance && !force)) return;

        const token = musicLoadToken + 1;
        musicLoadToken = token;
        setMusicLoading(true);
        resetMusicMount();
        showMusicStatus("音乐加载中...");

        let fallbackId = musicMount.dataset.fallbackId;

        try {
          const config = await getPlaylistConfig();
          if (token !== musicLoadToken) return;
          fallbackId = config.tracks[0] || fallbackId;

          if (config.tracks.length === 0) {
            showMusicStatus("歌单为空，请在 playlist.json 中添加歌曲 ID。");
            return;
          }

          await ensureAPlayer();
          if (token !== musicLoadToken) return;

          const audio = await getMusicPlaylist(config);
          if (token !== musicLoadToken) return;

          if (audio.length === 0) {
            loadFallbackFrame(config.tracks[0]);
            return;
          }

          resetMusicMount();
          musicPlayerInstance = new window.APlayer({
            container: musicMount,
            audio,
            autoplay: true,
            loop: "all",
            order: "list",
            preload: "auto",
            mutex: true,
            listFolded: true,
            listMaxHeight: "260px",
            storageName: "blog-music-player",
            volume: 0.7,
          });
          restoreInitialVolume();
          installAPlayerVolumeFix();
        } catch {
          if (fallbackId) {
            loadFallbackFrame(fallbackId);
          } else {
            showMusicStatus("音乐加载失败。");
          }
        } finally {
          if (token !== musicLoadToken) return;
          setMusicLoading(false);
        }
      };

      const reloadMusicFrame = () => {
        loadMusicPlayer({ force: true });
      };

      musicToggle?.addEventListener("click", () => {
        musicPlayer.dataset.open = "true";
        musicToggle.setAttribute("aria-expanded", "true");
        loadMusicPlayer();
      });

      musicRefresh?.addEventListener("click", reloadMusicFrame);

      musicClose?.addEventListener("click", () => {
        musicPlayer.dataset.open = "false";
        musicToggle?.setAttribute("aria-expanded", "false");
        setMusicLoading(false);
      });
    </script>
  </body>
</html>
